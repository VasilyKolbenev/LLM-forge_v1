# Pulsar AI — Configuration
# Copy to .env and fill in values

# ── Environment ─────────────────────────────────────────
# PULSAR_ENV=development           # development | production
#   In production mode, PULSAR_DB_URL and PULSAR_JWT_SECRET are required.
#   See .env.production for a full production template.

# ── Server ──────────────────────────────────────────────
PULSAR_PORT=8888
PULSAR_CORS_ORIGINS=http://localhost:8888
PULSAR_STAND_MODE=dev              # dev | demo (read-only for presentations)

# ── Authentication ──────────────────────────────────────
PULSAR_AUTH_ENABLED=false
PULSAR_JWT_SECRET=                 # Required in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"

# ── Database ────────────────────────────────────────────
# Default: SQLite at ./data/pulsar.db (no config needed)
# PULSAR_DB_URL=postgresql://pulsar:secret@localhost:5432/pulsar_ai

# ── Job Queue ───────────────────────────────────────────
# Default: in-process thread pool (no config needed)
# PULSAR_REDIS_URL=redis://localhost:6379/0

# ── Artifact Storage ───────────────────────────────────
# Default: local filesystem at ./data/artifacts
# PULSAR_S3_BUCKET=                # S3 bucket for model artifacts
# PULSAR_S3_ENDPOINT=              # Custom S3 endpoint (MinIO etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Logging ─────────────────────────────────────────────
PULSAR_LOG_LEVEL=INFO
PULSAR_LOG_FORMAT=console          # console | json (json for production)

# ── External APIs ──────────────────────────────────────
OPENAI_API_KEY=                    # For AI assistant and chat widget
