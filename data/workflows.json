          "label": "Support Agent",
          "config": {
            "framework": "forge-react",
            "tools": [
              "search",
              "calculator"
            ],
            "memory_type": "short_term",
            "max_iterations": 10
          }
        }
      },
      {
        "id": "n5",
        "type": "dataGen",
        "position": {
          "x": 800,
          "y": 200
        },
        "data": {
          "label": "Generate SFT Data",
          "config": {
            "output_format": "sft",
            "num_samples": 500,
            "include_reasoning": true,
            "filter_quality": true
          }
        }
      },
      {
        "id": "n6",
        "type": "training",
        "position": {
          "x": 1050,
          "y": 200
        },
        "data": {
          "label": "Fine-Tune on Traces",
          "config": {
            "task": "sft",
            "lr": 0.0001,
            "epochs": 2
          }
        }
      }
