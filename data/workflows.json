  {
    "id": "demo-wf-closed-loop",
    "name": "Closed-Loop Agent Improvement",
    "nodes": [
      {
        "id": "n1",
        "type": "dataSource",
        "position": { "x": 50, "y": 200 },
        "data": {
          "label": "Production Logs",
          "config": {
            "path": "data/agent_logs.jsonl",
            "format": "jsonl"
          }
        }
      },
      {
        "id": "n2",
        "type": "agent",
        "position": { "x": 280, "y": 200 },
        "data": {
          "label": "Collect Traces",
          "config": {
            "framework": "forge-react",
            "agent_role": "trace_collector",
            "tools": ["read_file", "search_files"],
            "max_iterations": 10
          }
        }
      },
      {
        "id": "n3",
        "type": "dataGen",
        "position": { "x": 520, "y": 200 },
        "data": {
          "label": "Build SFT Dataset",
          "config": {
            "output_format": "sft",
            "num_samples": 1000,
            "include_reasoning": true,
            "filter_quality": true
          }
        }
      },
      {
        "id": "n4",
        "type": "training",
        "position": { "x": 760, "y": 200 },
        "data": {
          "label": "SFT Training",
          "config": {
            "task": "sft",
            "lr": 2e-4,
            "epochs": 3,
            "batch_size": 4,
            "lora_r": 16,
            "lora_alpha": 32
          }
        }
      },
      {
        "id": "n5",
        "type": "eval",
        "position": { "x": 1000, "y": 200 },
        "data": {
          "label": "Evaluate",
          "config": {
            "batch_size": 8,
            "max_tokens": 512,
            "metrics": ["accuracy", "f1", "latency"]
          }
        }
      },
      {
        "id": "n6",
        "type": "conditional",
        "position": { "x": 1240, "y": 200 },
        "data": {
          "label": "Pass threshold?",
          "config": {
            "metric_name": "accuracy",
            "operator": ">=",
            "threshold": 0.85
          }
        }
      },
      {
        "id": "n7",
        "type": "export",
        "position": { "x": 1480, "y": 200 },
        "data": {
          "label": "Export Model",
          "config": {
            "format": "gguf",
            "quantization": "q4_k_m"
          }
        }
      }
    ],
