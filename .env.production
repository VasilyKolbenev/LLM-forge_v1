# Pulsar AI — Production Configuration
# Copy to .env and fill in ALL values before deploying.

# ── Environment (REQUIRED) ──────────────────────────────
PULSAR_ENV=production

# ── Server ──────────────────────────────────────────────
PULSAR_PORT=8888
PULSAR_CORS_ORIGINS=https://your-domain.com
PULSAR_STAND_MODE=dev

# ── Authentication (REQUIRED) ──────────────────────────
PULSAR_AUTH_ENABLED=true
PULSAR_JWT_SECRET=                 # REQUIRED. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"

# ── PostgreSQL (REQUIRED) ──────────────────────────────
PULSAR_DB_URL=postgresql://pulsar:secret@postgres:5432/pulsar_ai
PULSAR_PG_PASSWORD=                # Set a strong password, used by docker-compose for the postgres container

# ── Redis ───────────────────────────────────────────────
PULSAR_REDIS_URL=redis://redis:6379/0

# ── S3 / MinIO Artifact Storage ────────────────────────
PULSAR_S3_BUCKET=pulsar-artifacts
PULSAR_S3_ENDPOINT=                # Leave empty for AWS S3, set for MinIO (e.g. http://minio:9000)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Logging ─────────────────────────────────────────────
PULSAR_LOG_LEVEL=INFO
PULSAR_LOG_FORMAT=json

# ── External APIs ──────────────────────────────────────
OPENAI_API_KEY=
